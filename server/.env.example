PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<db-user>:<db-password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=https://your-frontend.vercel.app
ACCOUNT_CODE_TTL_MINUTES=15
SUPER_ADMIN_EMAIL=admin@finance.gov.pk
SUPER_ADMIN_PASSWORD=Admin123@
SUPER_ADMIN_MOBILE=03000000000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="HR Finance <no-reply@example.com>"
